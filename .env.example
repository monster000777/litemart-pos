DATABASE_URL=file:./dev.db
TEST_DATABASE_URL=file:./test.db
NUXT_AUTH_SECRET=

# AI Provider 配置（OpenAI 兼容协议）
# 可选值：openai | minimax | dify，留空则按下方是否填写自动识别
NUXT_AI_PROVIDER=
NUXT_AI_API_KEY=
NUXT_AI_API_URL=
NUXT_AI_MODEL=

# MiniMax 旧版兼容配置（无 NUXT_AI_* 时生效）
NUXT_MINIMAX_API_KEY=
NUXT_MINIMAX_API_URL=
NUXT_MINIMAX_MODEL=

# Dify Agent 配置
# 启用方式（任选其一）：
#   1) NUXT_AI_PROVIDER=dify + 下方 KEY/URL
#   2) 仅配置 NUXT_DIFY_API_KEY，自动识别为 Dify 并使用官方默认地址
# 关闭方式：清空 NUXT_DIFY_API_KEY / NUXT_DIFY_API_URL
NUXT_DIFY_API_KEY=
NUXT_DIFY_API_URL=
# 可选：用于隔离多套环境共享同一 Dify 时的用户/会话数据
# 设置后 Dify 的 user 字段会变成 "user_<APP_ID>:<userId>"
# 本地单套环境可以保持为空
NUXT_DIFY_APP_ID=

# Dify HTTP Tool auth token.
# Configure the same value in Dify tool Authorization: Bearer <token>.
NUXT_DIFY_TOOL_TOKEN=
