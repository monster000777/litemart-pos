{
  "name": "litemart-pos",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:miniapp": "eslint miniapp/src",
    "lint:miniapp:fix": "eslint miniapp/src --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed",
    "test:setup": "cross-env NODE_ENV=test TEST_DATABASE_URL=file:./test.db DATABASE_URL=file:./test.db prisma db push --accept-data-loss --skip-generate",
    "test": "cross-env NODE_ENV=test TEST_DATABASE_URL=file:./test.db DATABASE_URL=file:./test.db npm run test:setup && vitest run --fileParallelism false",
    "test:watch": "cross-env NODE_ENV=test TEST_DATABASE_URL=file:./test.db DATABASE_URL=file:./test.db vitest --fileParallelism false"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.8.2",
    "@pinia/nuxt": "^0.11.2",
    "@prisma/client": "^5.22.0",
    "@types/dompurify": "^3.0.5",
    "@types/marked": "^5.0.2",
    "dompurify": "^3.4.1",
    "lucide-vue-next": "^0.469.0",
    "marked": "^18.0.2",
    "nuxt": "^4.4.2",
    "pinia-plugin-persistedstate": "^4.5.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@nuxtjs/tailwindcss": "^6.13.2",
    "@tailwindcss/typography": "^0.5.19",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.5.1",
    "postcss": "^8.4.49",
    "prettier": "^3.6.2",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.46.2",
    "vitest": "^4.1.6",
    "vue-eslint-parser": "^10.2.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
