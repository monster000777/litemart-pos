generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id         String      @id @default(cuid())
  name       String
  sku        String      @unique
  image      String?
  price      Decimal
  stock      Int         @default(0)
  category   String
  minStock   Int         @default(0)
  orderItems OrderItem[]
  createdAt  DateTime    @default(now())
}

model Order {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  totalAmount  Decimal
  status       String      @default("COMPLETED")
  customerTail String?
  items        OrderItem[]
  createdAt    DateTime    @default(now())
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Config {
  id        String   @id @default("singleton")
  adminPin  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}
