generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id              String           @id @default(cuid())
  name            String
  sku             String           @unique
  image           String?
  price           Decimal
  memberPrice     Decimal?
  costPrice       Decimal          @default(0)
  stock           Int              @default(0)
  category        String
  minStock        Int              @default(0)
  supplierId      String?
  supplier        Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  purchaseItems   PurchaseItem[]
  createdAt       DateTime         @default(now())

  @@index([supplierId])
}

model Order {
  id             String      @id @default(cuid())
  orderNo        String      @unique
  totalAmount    Decimal
  status         String      @default("COMPLETED")
  customerTail   String?
  memberId       String?
  pointsUsed     Int         @default(0)
  pointsEarned   Int         @default(0)
  discountAmount Decimal     @default(0)
  member         Customer?   @relation(fields: [memberId], references: [id], onDelete: SetNull)
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@index([memberId])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  unitPrice Decimal
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Config {
  id        String   @id @default("singleton")
  adminPin  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuthUser {
  id        String   @id @default(cuid())
  name      String
  pinHash   String
  role      String   @default("CASHIER")
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([role])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  detail    String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
}

model Customer {
  id        String     @id @default(cuid())
  phone     String     @unique
  name      String?
  points    Int        @default(0)
  level     String     @default("NORMAL")
  createdAt DateTime   @default(now())
  orders    Order[]
  pointLogs PointLog[]

  @@index([phone])
  @@index([level])
}

model PointLog {
  id         String   @id @default(cuid())
  customerId String
  orderId    String?
  change     Int
  reason     String
  createdAt  DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([orderId])
}

model Supplier {
  id              String           @id @default(cuid())
  name            String
  contactName     String?
  phone           String?
  email           String?
  address         String?
  status          String           @default("ACTIVE")
  notes           String?
  products        Product[]
  purchaseOrders  PurchaseOrder[]
  createdAt       DateTime         @default(now())

  @@index([status])
}

model PurchaseOrder {
  id          String          @id @default(cuid())
  orderNo     String          @unique
  supplierId  String
  supplier    Supplier        @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  totalAmount Decimal
  status      String          @default("PENDING")
  notes       String?
  items       PurchaseItem[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([supplierId])
  @@index([status])
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity        Int
  unitCost        Decimal

  @@index([purchaseOrderId])
  @@index([productId])
}
