# API Environment Configuration Template
# Copy this file to .env.dev-lan or .env.production and customize for your environment

# API Environment: 'lan' | 'prod'
# - lan: 局域网开发联调 (内网 IP，推荐本地开发使用)
# - prod: 生产发布 (真实域名)
VITE_API_ENV=lan

# API Base URL (if empty, uses default based on VITE_API_ENV)
# IMPORTANT: 必须改成你开发机的实际 IP 地址！
# Examples:
#   http://192.168.1.100:3000       (开发机内网 IP - 推荐)
#   https://YOUR_API_DOMAIN.com     (生产环境)
# 
# ⚠️ 注意：127.0.0.1 在微信开发者工具沙箱内无法访问，必须用真实 IP
VITE_API_BASE_URL=http://192.168.1.100:3000

# Request timeout in milliseconds (default: 12000 = 12 seconds)
# Prod timeout is recommended to be 18000ms for better stability
VITE_REQUEST_TIMEOUT=12000
